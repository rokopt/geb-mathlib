module

public import Geb.Mathlib.Data.PFunctor.IndRec.Basic

/-!
# Tests for inductive-recursive codes

One-step name constructors (`stepIota`, `stepSigma`, `stepPi`) build
elements of one application of the universe endofunctor `univEndo` to
a given universe, generically in the starting types and the given
universe; `rfl` tests check that their decodings are the expected
lifted starting types, dependent sums, and dependent products.

The starting types are then instantiated at a two-part family ÔÇö the
natural numbers and every finite type ÔÇö and the endofunctor is
iterated from the empty universe, adjoining names whose decodings mix
both starting types under dependent sums and dependent products.

The morphism action is exercised at the algebra level
(`IR.interpMorStep`), where it computes by `rfl`; `univEndoMor` itself
is generated by `IR.rec`, whose computation rule is propositional
rather than definitional, so its applications do not reduce
definitionally.

Heterogeneous codes (`IR I O` with `I Ôëá O`) are interpreted at a
sample object, checking that the interpretation maps a family over
the input index type to a family over the output index type, and
that the `delta` interpretation consumes the input-typed decodings
of its recursive arguments.

A container is translated to an `IR` code over the unit type by
`contCode`; `rfl` tests check that an interpreted name decodes to
the unit element, including at separated arity universes.

## Tags

inductive-recursive, polynomial functor, universe, container
-/

-- The type-valued test definitions must be `@[expose]`d so their
-- compilation types match across modules (a compiler limitation for
-- `module`s), and `expose` is meaningful on public definitions only.
@[expose] public section

open CategoryTheory IndRec

universe uK uT

section StepConstructors

variable (K : Type uK) (T : K Ôćĺ Type uT)
    (X : FreeCoprodCompDisc.{max uK uT, max uK uT + 1} (Type (max uK uT)))

/-- The name, in one application of `univEndo` to `X`, of the starting
type selected by `k`. -/
def stepIota (k : K) : (univEndo K T X).1 :=
  ÔčĘSum.inl k, ULift.up ()Ôčę

-- A starting-type name decodes to the lifted starting type.
example (k : K) : (univEndo K T X).2 (stepIota K T X k) = ULift.{uK} (T k) :=
  rfl

/-- The name, in one application of `univEndo` to `X`, of the dependent
sum over the name `a` of the family of names `b`. -/
def stepSigma (a : X.1) (b : X.2 a Ôćĺ X.1) : (univEndo K T X).1 :=
  ÔčĘSum.inr (Sum.inl PUnit.unit), fun _ ÔćŽ a, b, ULift.up ()Ôčę

-- A dependent-sum name decodes to the dependent sum of the decodings.
example (a : X.1) (b : X.2 a Ôćĺ X.1) :
    (univEndo K T X).2 (stepSigma K T X a b) = ╬ú x : X.2 a, X.2 (b x) :=
  rfl

/-- The name, in one application of `univEndo` to `X`, of the dependent
product over the name `a` of the family of names `b`. -/
def stepPi (a : X.1) (b : X.2 a Ôćĺ X.1) : (univEndo K T X).1 :=
  ÔčĘSum.inr (Sum.inr PUnit.unit), fun _ ÔćŽ a, b, ULift.up ()Ôčę

-- A dependent-product name decodes to the dependent product of the
-- decodings.
example (a : X.1) (b : X.2 a Ôćĺ X.1) :
    (univEndo K T X).2 (stepPi K T X a b) = ((x : X.2 a) Ôćĺ X.2 (b x)) :=
  rfl

end StepConstructors

section NatFin

/-- The starting-type index: one tag for `Nat` and one tag per finite
type. -/
def NatFinIdx : Type := Unit ÔŐĽ Nat

/-- The starting types: `Nat`, and `Fin n` for each `n`. -/
def NatFinTypes : NatFinIdx Ôćĺ Type := Sum.elim (fun _ ÔćŽ Nat) (fun n ÔćŽ Fin n)

/-- The universe endofunctor generated by `NatFinTypes`. -/
def natFinEndo : FreeCoprodCompDisc.Endo.{0, 1} Type :=
  univEndo NatFinIdx NatFinTypes

/-- Iteration stage zero: the empty universe. -/
def stage0 : FreeCoprodCompDisc.{0, 1} Type := ÔčĘPEmpty, PEmpty.elimÔčę

/-- Iteration stage one: names for the starting types. -/
def stage1 : FreeCoprodCompDisc.{0, 1} Type := natFinEndo stage0

/-- Iteration stage two: fresh names for the starting types, and
dependent sums and dependent products of stage-one names. -/
def stage2 : FreeCoprodCompDisc.{0, 1} Type := natFinEndo stage1

/-- Iteration stage three: fresh names for the starting types, and
dependent sums and dependent products of stage-two names. -/
def stage3 : FreeCoprodCompDisc.{0, 1} Type := natFinEndo stage2

/-- The stage-one name of `Nat`. -/
def natName : stage1.1 := stepIota NatFinIdx NatFinTypes stage0 (Sum.inl ())

/-- The stage-one name of `Fin n`. -/
def finName (n : Nat) : stage1.1 :=
  stepIota NatFinIdx NatFinTypes stage0 (Sum.inr n)

example : stage1.2 natName = ULift Nat := rfl
example : stage1.2 (finName 5) = ULift (Fin 5) := rfl

/-- The stage-two name of `Nat` (each stage renames the starting
types). -/
def natName2 : stage2.1 := stepIota NatFinIdx NatFinTypes stage1 (Sum.inl ())

/-- The stage-one family assigning to each `n : Nat` the name of
`Fin (n + 1)`. -/
def finSuccFamily : stage1.2 natName Ôćĺ stage1.1 :=
  fun (n : ULift Nat) ÔćŽ finName (n.down + 1)

/-- The stage-two name of the dependent sum `╬ú n : Nat, Fin (n + 1)`. -/
def sigmaName : stage2.1 :=
  stepSigma NatFinIdx NatFinTypes stage1 natName finSuccFamily

-- The dependent-sum name decodes to the expected dependent sum, mixing
-- both starting types.
example : stage2.2 sigmaName = ╬ú n : ULift Nat, ULift (Fin (n.down + 1)) :=
  rfl

-- The decoded dependent sum has the expected inhabitants.
example : stage2.2 sigmaName := ÔčĘULift.up (3 : Nat), ULift.up (2 : Fin 4)Ôčę

/-- The stage-two name of the dependent product `(n : Nat) Ôćĺ Fin (n + 1)`. -/
def piName : stage2.1 :=
  stepPi NatFinIdx NatFinTypes stage1 natName finSuccFamily

-- The dependent-product name decodes to the expected dependent product.
example : stage2.2 piName = ((n : ULift Nat) Ôćĺ ULift (Fin (n.down + 1))) :=
  rfl

-- The decoded dependent product has the expected inhabitants.
example : stage2.2 piName :=
  fun (n : ULift Nat) ÔćŽ ULift.up (0 : Fin (n.down + 1))

/-- The stage-three name of `╬ú _ : ((n : Nat) Ôćĺ Fin (n + 1)), Nat`: a
dependent sum over a stage-two dependent-product name. -/
def sigmaPiName : stage3.1 :=
  stepSigma NatFinIdx NatFinTypes stage2 piName (fun _ ÔćŽ natName2)

-- Iterated formation: the stage-three decoding nests a stage-two
-- dependent product inside a dependent sum.
example : stage3.2 sigmaPiName =
    ╬ú _ : ((n : ULift Nat) Ôćĺ ULift (Fin (n.down + 1))), ULift Nat :=
  rfl

end NatFin

section MorphismAction

-- The morphism action is tested through `IR.interpMorStep` (one
-- algebra step), which computes by `rfl`; `IR.interpMor` routes
-- through `IR.rec`, whose computation rule is propositional.

/-- A domain object: one point, decoding to `Nat`. -/
def morSrc : FreeCoprodCompDisc.{0, 1} Type := ÔčĘUnit, fun _ ÔćŽ NatÔčę

/-- A codomain object: two points, decoding to `Nat`. -/
def morTgt : FreeCoprodCompDisc.{0, 1} Type := ÔčĘBool, fun _ ÔćŽ NatÔčę

/-- A morphism from `morSrc` to `morTgt`: the point maps to `true`. -/
def morHom : FreeCoprodCompDisc.Hom Type morSrc morTgt :=
  ÔčĘfun _ ÔćŽ true, rflÔčę

/-- The decoding assigned to each index of the sigma test code. -/
def SigmaTestDecode : Bool Ôćĺ Type :=
  fun b ÔćŽ if b then Nat else Bool

/-- The subcodes of a sigma test code over `Bool`: `iota` codes
decoding to `Nat` and `Bool`. -/
def sigmaTestSub : Bool Ôćĺ IR.{0, 0, 1, 1} Type Type :=
  fun b ÔćŽ IR.iota Type Type (SigmaTestDecode b)

/-- The sigma-case morphism action of `IR.interpMorStep` at `morHom`. -/
def sigmaTestMor :
    FreeCoprodCompDisc.Hom Type
      (IR.interpObj Type Type (IR.sigma Type Type Bool sigmaTestSub) morSrc)
      (IR.interpObj Type Type (IR.sigma Type Type Bool sigmaTestSub) morTgt) :=
  IR.interpMorStep Type Type (Sum.inr (Sum.inl Bool))
    (sigmaTestSub Ôłś ULift.down)
    (fun b ÔćŽ IR.interpMorIota Type Type (SigmaTestDecode (ULift.down b)))
    morSrc morTgt morHom

-- The sigma action preserves the tag and the payload.
example : sigmaTestMor.1 ÔčĘtrue, ULift.up ()Ôčę = ÔčĘtrue, ULift.up ()Ôčę := rfl

/-- The decoding assigned to each index of the delta test code: the
decoding assigned to `true`. -/
def DeltaTestDecode : (Bool Ôćĺ Type) Ôćĺ Type :=
  fun f ÔćŽ f true

/-- The subcodes of a delta test code over `Bool`: `iota` codes at the
index decodings. -/
def deltaTestSub : (Bool Ôćĺ Type) Ôćĺ IR.{0, 0, 1, 1} Type Type :=
  fun f ÔćŽ IR.iota Type Type (DeltaTestDecode f)

/-- The delta-case morphism action of `IR.interpMorStep` at `morHom`. -/
def deltaTestMor :
    FreeCoprodCompDisc.Hom Type
      (IR.interpObj Type Type (IR.delta Type Type Bool deltaTestSub) morSrc)
      (IR.interpObj Type Type (IR.delta Type Type Bool deltaTestSub) morTgt) :=
  IR.interpMorStep Type Type (Sum.inr (Sum.inr Bool))
    (deltaTestSub Ôłś ULift.down)
    (fun f ÔćŽ IR.interpMorIota Type Type (DeltaTestDecode (ULift.down f)))
    morSrc morTgt morHom

-- The delta action reindexes a name by postcomposition with the
-- morphism and preserves the payload.
example :
    deltaTestMor.1 ÔčĘfun _ ÔćŽ (), ULift.up ()Ôčę =
      ÔčĘfun _ ÔćŽ true, ULift.up ()Ôčę :=
  rfl

-- The image of a name decodes to the same type as the name.
example :
    (IR.interpObj Type Type (IR.delta Type Type Bool deltaTestSub) morTgt).2
        (deltaTestMor.1 ÔčĘfun _ ÔćŽ (), ULift.up ()Ôčę) =
      Nat :=
  rfl

end MorphismAction

section Heterogeneous

-- A heterogeneous code `IR I O` with `I Ôëá O` denotes a functor from the
-- free coproduct completion of `I` to that of `O`, not an endofunctor.

/-- A heterogeneous `IR` code with input index type `Nat` and output
index type `Bool`: the constant `iota` code at `true`. -/
def hetCode : IR.{0, 0, 0, 0} Nat Bool :=
  IR.iota Nat Bool true

/-- A domain object of the input completion: three names decoding to
their own indices. -/
def hetSrc : FreeCoprodCompDisc.{0, 0} Nat :=
  ÔčĘFin 3, fun i ÔćŽ iÔčę

/-- The codomain object that the heterogeneous `iota` code produces: a
singleton family decoding to `true`. -/
def hetTgt : FreeCoprodCompDisc.{0, 0} Bool :=
  IR.interpObj Nat Bool hetCode hetSrc

-- The output family has a single name.
example : hetTgt.1 = ULift Unit := rfl

-- That name decodes to `true`; the input `Nat` family is ignored by the
-- constant `iota` interpretation.
example : hetTgt.2 (ULift.up ()) = true := rfl

/-- A heterogeneous `delta` code: one recursive argument, whose
subcode decodes to whether the argument's input-index decoding is
even. -/
def hetDeltaCode : IR.{0, 0, 0, 0} Nat Bool :=
  IR.delta Nat Bool Unit (fun f ÔćŽ IR.iota Nat Bool (f () % 2 == 0))

/-- The codomain object that the heterogeneous `delta` code produces
at `hetSrc`: one name per assignment `Unit Ôćĺ Fin 3`, decoding to the
parity of the assigned index. -/
def hetDeltaTgt : FreeCoprodCompDisc.{0, 0} Bool :=
  IR.interpObj Nat Bool hetDeltaCode hetSrc

-- A name assigning the index `2` decodes to `true`: the `delta`
-- interpretation reindexes the input family along the assignment.
example : hetDeltaTgt.2 ÔčĘfun _ ÔćŽ (2 : Fin 3), ULift.up ()Ôčę = true := rfl

-- A name assigning the index `1` decodes to `false`.
example : hetDeltaTgt.2 ÔčĘfun _ ÔćŽ (1 : Fin 3), ULift.up ()Ôčę = false := rfl

end Heterogeneous

section Container

-- A simple container (a `PFunctor`) is translated to an `IR` code
-- over the unit type by `contCode`.

/-- A test container: shape `Bool`, with `Nat` directions under each
shape. -/
def testCont : PFunctor.{0, 0} := ÔčĘBool, fun _ ÔćŽ NatÔčę

/-- The `IR` code over the unit type representing `testCont`. -/
def testContCode : IR.{0, 0, 0, 0} PUnit PUnit := contCode testCont

/-- An input family over the unit type: a single name. -/
def testContX : FreeCoprodCompDisc.{0, 0} PUnit :=
  ÔčĘPUnit, fun _ ÔćŽ PUnit.unitÔčę

-- A name in the interpreted container pairs a shape, a direction
-- assignment into the input family, and the single name of the
-- constant `iota` interpretation; it decodes to the unit element
-- (Example 1's `(s : S) ├Ś (P s Ôćĺ X) ├Ś 1`).
example (s : Bool) (g : Nat Ôćĺ PUnit) :
    (IR.interpObj PUnit PUnit testContCode testContX).2
        ÔčĘs, g, ULift.up ()Ôčę = PUnit.unit :=
  rfl

/-- A test container with separated field universes: shape `ULift Bool`
at universe `1`, with `Nat` directions at universe `0` under each
shape. -/
def testContSep : PFunctor.{1, 0} := ÔčĘULift Bool, fun _ ÔćŽ NatÔčę

/-- The `IR` code over the unit type representing `testContSep`: the
arity universes are instantiated off the diagonal (`uA Ôëá uB`). -/
def testContSepCode : IR.{1, 0, 0, 0} PUnit PUnit := contCode testContSep

/-- An input family over the unit type at the matching index universe:
a single name. -/
def testContSepX : FreeCoprodCompDisc.{1, 0} PUnit :=
  ÔčĘPUnit, fun _ ÔćŽ PUnit.unitÔčę

-- The interpreted-name decoding is preserved at separated arity
-- universes.
example (s : ULift Bool) (g : Nat Ôćĺ PUnit) :
    (IR.interpObj PUnit PUnit testContSepCode testContSepX).2
        ÔčĘs, g, ULift.up ()Ôčę = PUnit.unit :=
  rfl

end Container

section Precomp

/-- A sample delta code: one boolean recursive arity, decoding
to the unit. -/
def sampleDeltaCode : IR.{0, 0, 0, 0} Bool PUnit :=
  IR.delta Bool PUnit Bool (fun _ ÔćŽ IR.iota Bool PUnit PUnit.unit)

/-- The merged assignment takes resolved arity elements from
`i`. -/
theorem samplePrecompMerge_inl (b : Bool) :
    IR.precompMerge Bool PUnit.{1} (fun _ ÔćŽ true)
      (fun _ : Bool ÔćŽ Sum.inl PUnit.unit)
      (fun j ÔćŽ nomatch j.2) b = true :=
  rfl

/-- The merged assignment takes unresolved arity elements from
the direction assignment. -/
theorem samplePrecompMerge_inr (b : Bool) :
    IR.precompMerge Bool PUnit.{1} (fun _ ÔćŽ true)
      (fun _ : Bool ÔćŽ Sum.inr PUnit.unit) (fun _ ÔćŽ false) b =
      false :=
  rfl

/-- The delta computation rule at the sample code. -/
theorem samplePrecomp_delta :
    IR.precomp Bool PUnit PUnit.{1} (fun _ ÔćŽ true) sampleDeltaCode =
      IR.sigma Bool PUnit (ULift.{0} (Bool Ôćĺ PUnit ÔŐĽ PUnit.{1}))
        (fun cl ÔćŽ
          IR.delta Bool PUnit
            {b : Bool // cl.down b = Sum.inr PUnit.unit}
            (fun _ ÔćŽ IR.iota Bool PUnit PUnit.unit)) :=
  rfl

end Precomp
